{
  "name": "backstage",
  "version": "0.0.1",
  "private": true,
  "packageManager": "yarn@4.8.1",
  "engines": {
    "node": "22 || 24"
  },
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "build:app": "yarn workspace app build",
    "build:backend": "yarn workspace backend build",
    "build": "yarn build:app && yarn build:backend",
    "start:backend": "yarn workspace backend start",
    "clean": "yarn workspace backend clean"
  },
  "devDependencies": {
    "@backstage/cli": "^0.27.0",
    "typescript": "~5.7.0"
  }
}
